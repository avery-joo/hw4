<h1><%= @place["name"] %></h1>

<div class="d-flex justify-content-between align-items-center mb-4">
  <% if session["user_id"] != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">New Post</a>
  <% end %>
</div>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <%# 1. 제목 %>
          <h5 class="card-title fw-bold"><%= entry["title"] %></h5>
          
          <%# 2. 날짜 %>
          <h6 class="card-subtitle mb-3 text-muted"><%= entry["occurred_on"] %></h6>

          <%# 3. 이미지 %>
          <div class="mb-3">
            <% if entry.uploaded_image.attached? %>
              <img src="<%= url_for(entry.uploaded_image) %>" class="img-fluid rounded">
            <% else %>
              <img src="<%= entry["image"] %>" class="img-fluid rounded">
            <% end %>
          </div>

          <%# 4. 설명 %>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-4">
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</div>